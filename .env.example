# Anthropic API Key (required for backend - set on Render)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Backend API URL (required for frontend - set on Netlify)
# After deploying server to Render, use: https://your-app-name.onrender.com
VITE_API_URL=http://localhost:3001
